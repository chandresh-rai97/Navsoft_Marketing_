# Supabase connection — these are the browser-safe PUBLIC keys.
# Row Level Security (RLS) is what protects your data, not the secrecy of these values.
# Copy this file to `.env` and fill in your own project's values if you fork the backend.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key
